{
  "documentTitle": "甘肃省高风险放射源监管平台建设方案",
  "figures": [
    {
      "type": "flowchart",
      "placement": "业务方案 / 风险预警处置",
      "title": "放射源风险预警处置闭环图",
      "subtitle": "业务方案 / 告警发现、研判与处置",
      "nodes": [
        {"id": "device", "title": "定位终端采集", "desc": "状态与位置", "row": 0, "col": 0, "icon": "terminal"},
        {"id": "monitor", "title": "实时监测分析", "desc": "轨迹与状态", "row": 0, "col": 1, "kind": "external", "icon": "location"},
        {"id": "alert", "title": "触发预警?", "row": 0, "col": 2, "kind": "decision", "icon": "alert"},
        {"id": "normal", "title": "持续监测", "desc": "状态正常", "row": 0, "col": 3, "kind": "success", "icon": "check"},
        {"id": "task", "title": "生成处置任务", "desc": "推送监管人员", "row": 1, "col": 2, "icon": "workflow"},
        {"id": "handle", "title": "核查与处置", "desc": "记录处置结果", "row": 1, "col": 3, "icon": "government"},
        {"id": "closed", "title": "闭环归档", "desc": "形成监管台账", "row": 1, "col": 4, "kind": "success", "icon": "report"}
      ],
      "edges": [
        {"from": "device", "to": "monitor"},
        {"from": "monitor", "to": "alert"},
        {"from": "alert", "to": "normal", "label": "否"},
        {"from": "alert", "to": "task", "label": "是"},
        {"from": "task", "to": "handle"},
        {"from": "handle", "to": "closed"}
      ],
      "note": "处置节点依据监管闭环思路表达，预警规则和岗位职责需在业务制度确认后细化。"
    }
  ]
}
