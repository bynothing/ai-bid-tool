{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "s1_risk",
  "title": "项目风险分析报告",
  "description": "阶段1输出：全面识别项目风险，每项附应对策略",
  "type": "object",
  "required": ["risks", "risk_summary", "overall_risk_level"],
  "properties": {
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "category", "description", "level", "mitigation", "bid_strategy"],
        "properties": {
          "id": { "type": "string", "pattern": "^RQ-RISK-\\d{3}$" },
          "category": {
            "type": "string",
            "enum": [
              "资质风险", "涉密风险", "工期节点风险",
              "第三方检测风险", "技术集成风险", "驻场政审风险",
              "报价限价风险", "恶意低价判定风险", "知识产权风险",
              "人员流失风险", "验收不通过风险", "其他"
            ]
          },
          "description": { "type": "string", "minLength": 10 },
          "trigger_condition": { "type": "string", "description": "触发条件/场景" },
          "level": { "type": "string", "enum": ["低", "中", "高", "致命"] },
          "probability": { "type": "string", "enum": ["极低", "低", "中", "高", "极高"] },
          "impact": { "type": "string", "minLength": 5, "description": "影响描述" },
          "mitigation": { "type": "string", "minLength": 10, "description": "规避方案" },
          "bid_strategy": { "type": "string", "minLength": 5, "description": "投标应答策略" },
          "owner": { "type": "string", "description": "风险责任人角色" }
        }
      }
    },
    "risk_summary": {
      "type": "object",
      "required": ["fatal_count", "high_count", "medium_count", "low_count"],
      "properties": {
        "fatal_count": { "type": "integer" },
        "high_count": { "type": "integer" },
        "medium_count": { "type": "integer" },
        "low_count": { "type": "integer" }
      }
    },
    "overall_risk_level": { "type": "string", "enum": ["低", "中", "高", "不可接受"] },
    "go_no_go_recommendation": { "type": "string", "enum": ["建议投标", "有条件投标", "不建议投标"] }
  }
}
