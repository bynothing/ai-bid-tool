{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "s7_trace_matrix",
  "title": "评分标准-投标响应一一对应对照表",
  "description": "阶段7输出：完整闭环校验，证明100%响应无遗漏",
  "type": "object",
  "required": ["mappings", "coverage_result", "sign_off"],
  "properties": {
    "document_title": { "type": "string" },
    "bidder_name": { "type": "string" },
    "project_name": { "type": "string" },
    "check_date": { "type": "string", "format": "date" },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "req_id", "req_text", "req_type", "response_chapter",
          "response_summary", "is_fully_responded", "deviation"
        ],
        "properties": {
          "req_id": { "type": "string" },
          "req_text": { "type": "string", "minLength": 5 },
          "req_type": { "type": "string", "enum": ["★实质性条款", "强制性条款", "一般性要求", "评分要点"] },
          "req_source": { "type": "string" },
          "score_weight": { "type": "number", "description": "评分权重（如有）" },
          "response_chapter": { "type": "string", "description": "响应章节编号" },
          "response_page": { "type": "string", "description": "响应页码（Word导出后填写）" },
          "response_summary": { "type": "string", "minLength": 10 },
          "is_fully_responded": { "type": "boolean" },
          "deviation": { "type": "string", "enum": ["无偏离", "正偏离", "负偏离（已说明）", "替代方案"] },
          "deviation_note": { "type": "string" },
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "verified_by": { "type": "string" }
        }
      }
    },
    "coverage_result": {
      "type": "object",
      "required": ["total_reqs", "fully_covered", "partial_covered", "uncovered", "coverage_rate"],
      "properties": {
        "total_reqs": { "type": "integer" },
        "fully_covered": { "type": "integer" },
        "partial_covered": { "type": "integer" },
        "uncovered": { "type": "integer" },
        "coverage_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "uncovered_req_ids": { "type": "array", "items": { "type": "string" } },
        "negative_deviation_req_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "chapter_coverage": {
      "type": "object",
      "description": "按章节统计覆盖的条款数",
      "additionalProperties": { "type": "integer" }
    },
    "sign_off": {
      "type": "object",
      "required": ["all_requirements_covered", "no_negative_deviation", "ready_for_submission"],
      "properties": {
        "all_requirements_covered": { "type": "boolean" },
        "no_negative_deviation": { "type": "boolean" },
        "ready_for_submission": { "type": "boolean" },
        "reviewer_name": { "type": "string" },
        "review_date": { "type": "string" }
      }
    }
  }
}
