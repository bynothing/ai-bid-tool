{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "s1_key_info",
  "title": "项目关键信息提取表",
  "description": "阶段1输出：从招标文件提取的项目核心信息",
  "type": "object",
  "required": [
    "project_name", "procurement_unit", "project_type",
    "max_price", "duration_months", "warranty_months",
    "delivery_method", "response_validity_days",
    "star_clauses", "security_requirements"
  ],
  "properties": {
    "project_name": { "type": "string", "minLength": 2, "description": "项目名称" },
    "procurement_unit": { "type": "string", "minLength": 2, "description": "采购单位" },
    "project_type": { "type": "string", "enum": ["非标定制", "标准化产品", "系统集成", "定制开发", "施工总承包", "其他"] },
    "max_price": { "type": "number", "exclusiveMinimum": 0, "description": "最高限价（万元）" },
    "max_price_note": { "type": "string", "description": "限价补充说明（含税/不含税等）" },
    "duration_months": { "type": "number", "exclusiveMinimum": 0, "description": "工期（月）" },
    "warranty_months": { "type": "number", "minimum": 0, "description": "质保期（月）" },
    "delivery_method": { "type": "string", "description": "交付方式" },
    "response_validity_days": { "type": "number", "description": "响应有效期（天）" },
    "payment_terms": { "type": "string", "description": "付款方式" },
    "onsite_required": { "type": "boolean", "description": "是否要求驻场" },
    "security_level": { "type": "string", "enum": ["无", "秘密", "机密", "绝密", "涉密（未定级）", "其他"], "description": "涉密等级" },
    "intellectual_property": { "type": "string", "description": "知识产权归属要求" },
    "joint_venture_allowed": { "type": "boolean", "description": "是否允许联合体" },
    "subcontract_allowed": { "type": "boolean", "description": "是否允许分包" },
    "evaluation_method": { "type": "string", "enum": ["最低评审价法", "综合评分法", "经评审的最低投标价法", "其他"], "description": "评审方法" },
    "star_clauses": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "content", "clause_type"],
        "properties": {
          "id": { "type": "string", "pattern": "^RQ-[A-Z]+-\\d{3}$" },
          "content": { "type": "string", "minLength": 5 },
          "clause_type": { "type": "string", "enum": ["★实质性条款", "强制性条款", "废标条款"] },
          "consequence_if_fail": { "type": "string" }
        }
      }
    },
    "security_requirements": {
      "type": "object",
      "required": ["has_security_qualification", "qualification_level"],
      "properties": {
        "has_security_qualification": { "type": "boolean" },
        "qualification_level": { "type": "string" },
        "personnel_check_required": { "type": "boolean" },
        "offline_dev_required": { "type": "boolean" },
        "data_export_prohibited": { "type": "boolean" }
      }
    },
    "milestone_dates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["deadline_days", "deliverable"],
        "properties": {
          "deadline_days": { "type": "number" },
          "deliverable": { "type": "string" },
          "version": { "type": "string" }
        }
      }
    },
    "deliverables_list": {
      "type": "array",
      "items": { "type": "string" },
      "description": "交付物清单"
    }
  }
}
