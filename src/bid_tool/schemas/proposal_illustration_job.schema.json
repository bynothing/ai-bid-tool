{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.example/proposal-illustration-job.schema.json",
  "title": "Proposal Document Illustration Job",
  "type": "object",
  "required": ["version", "document", "illustrations"],
  "properties": {
    "version": { "const": "1.0" },
    "document": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "projectName": { "type": "string" },
        "bidSection": { "type": "string" }
      },
      "additionalProperties": false
    },
    "style": {
      "type": "object",
      "properties": {
        "theme": { "enum": ["clarity_blue", "navy_teal", "royal_gold", "slate_emerald"] },
        "preferredFormat": { "enum": ["svg", "png", "both"] }
      },
      "additionalProperties": false
    },
    "illustrations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/illustration" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "insertion": {
      "type": "object",
      "required": ["section", "caption"],
      "properties": {
        "section": { "type": "string", "minLength": 1 },
        "afterText": { "type": "string" },
        "caption": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string" }
      },
      "additionalProperties": false
    },
    "common": {
      "type": "object",
      "required": ["id", "renderer", "insertion", "spec"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_-]*$" },
        "renderer": { "enum": ["svg", "echarts_html"] },
        "insertion": { "$ref": "#/$defs/insertion" },
        "spec": { "type": "object" }
      }
    },
    "illustration": {
      "oneOf": [
        {
          "allOf": [
            { "$ref": "#/$defs/common" },
            {
              "type": "object",
              "properties": {
                "renderer": { "const": "svg" },
                "spec": {
                  "type": "object",
                  "required": ["type", "title"],
                  "properties": {
                    "type": {
                      "enum": [
                        "layered_architecture",
                        "flowchart",
                        "swimlane_flowchart",
                        "sequence_diagram",
                        "capability_map",
                        "relationship_map",
                        "timeline_milestone",
                        "gantt_plan",
                        "risk_matrix",
                        "comparison_cards",
                        "network_topology"
                      ]
                    },
                    "title": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/common" },
            {
              "type": "object",
              "properties": {
                "renderer": { "const": "echarts_html" },
                "spec": {
                  "type": "object",
                  "required": ["id", "type", "title", "note", "source"],
                  "properties": {
                    "type": { "enum": ["bar_line", "radar", "sankey", "pie_donut", "stacked_bar", "line_multi", "funnel", "gauge"] },
                    "title": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          ]
        }
      ]
    }
  }
}
