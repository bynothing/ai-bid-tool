{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "s1_veto_items",
  "title": "资格与符合性一票否决项清单",
  "description": "阶段1输出：所有可能导致直接废标的硬性准入条件",
  "type": "object",
  "required": ["items", "total_count", "zero_tolerance_count"],
  "properties": {
    "items": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "category", "requirement_text", "our_compliance", "evidence"],
        "properties": {
          "id": { "type": "string", "pattern": "^RQ-VETO-\\d{3}$" },
          "category": {
            "type": "string",
            "enum": [
              "企业资质", "人员要求", "财务要求", "无外资要求",
              "无失信要求", "保密资质", "政审要求", "驻场要求",
              "禁止联合体", "禁止分包", "知识产权", "报价限价",
              "工期要求", "质保要求", "文件合规", "其他"
            ]
          },
          "requirement_text": { "type": "string", "minLength": 10 },
          "source_ref": { "type": "string", "description": "招标文件出处（页码/条款号）" },
          "fail_consequence": { "type": "string", "description": "不满足的直接后果" },
          "our_compliance": { "type": "string", "enum": ["完全满足", "有风险需确认", "不满足"] },
          "evidence": { "type": "string", "minLength": 5, "description": "已有的证明材料或准备方式" },
          "risk_level": { "type": "string", "enum": ["无风险", "低风险", "中风险", "高风险", "致命"] }
        }
      }
    },
    "total_count": { "type": "integer", "minimum": 1 },
    "zero_tolerance_count": { "type": "integer", "description": "一票否决项数量" },
    "unmet_items": {
      "type": "array",
      "items": { "type": "string" },
      "description": "我方无法满足的条目 ID 列表（如非空则需最高级决策）"
    }
  }
}
