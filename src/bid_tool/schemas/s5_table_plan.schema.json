{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bid-tool.local/schemas/s5_table_plan.schema.json",
  "title": "Stage 5 Table Insertion Plan",
  "type": "object",
  "required": ["version", "document", "tables"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "document": {
      "type": "object",
      "required": ["title"],
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "projectName": { "type": "string" },
        "bidSection": { "type": "string" }
      }
    },
    "strategy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string" },
        "tableDensity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "avoidDuplicatingIllustrations": { "type": "boolean" }
      }
    },
    "tables": {
      "type": "array",
      "items": { "$ref": "#/$defs/table" }
    }
  },
  "$defs": {
    "table": {
      "type": "object",
      "required": ["id", "section", "title", "purpose", "columns", "rows"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^TB-[0-9]{3}$"
        },
        "section": {
          "type": "string",
          "pattern": "^CH-[0-9]{2}(\\.[0-9]+)?$"
        },
        "title": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "reason": { "type": "string" },
        "placement": {
          "type": "string",
          "enum": ["section_start", "section_end"],
          "default": "section_end"
        },
        "columns": {
          "type": "array",
          "minItems": 2,
          "maxItems": 8,
          "items": { "type": "string", "minLength": 1 }
        },
        "rows": {
          "type": "array",
          "minItems": 1,
          "maxItems": 30,
          "items": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string" }
          }
        },
        "sourceRefs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
